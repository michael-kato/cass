{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cass",
  "main": "server.js",
  "compatibility_date": "2026-04-02",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}